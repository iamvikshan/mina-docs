{
  "name": "mina-docs",
  "version": "1.0.0",
  "private": true,
  "description": "Amina documentation portal - API reference, developer wiki & user guides",
  "type": "module",
  "scripts": {
    "postinstall": "python3 scripts/patch-react-dom.py",
    "dev": "zudoku dev",
    "build": "zudoku build",
    "build:prd": "bun install --production --frozen-lockfile && zudoku build",
    "preview": "zudoku preview",
    "f": "(git diff --name-only --diff-filter=ACMR HEAD && git ls-files --others --exclude-standard) | xargs bunx prettier --write --ignore-unknown",
    "f:all": "prettier --write .",
    "f:check": "prettier --check .",
    "upd": "bun update --latest && bun f",
    "prepare": "test -d .git && husky || true"
  },
  "dependencies": {
    "zudoku": "^0.76.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
