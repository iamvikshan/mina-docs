{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":semanticCommits", ":dependencyDashboard"],
  "baseBranchPatterns": ["main"],
  "automerge": true,
  "prConcurrentLimit": 10,
  "prHourlyLimit": 5,
  "labels": ["dependencies"],
  "assignees": ["iamvikshan"],
  "schedule": ["before 4am every weekday"],
  "timezone": "Africa/Nairobi",
  "dependencyDashboardApproval": false,
  "rebaseWhen": "conflicted",
  "rangeStrategy": "bump",
  "separateMinorPatch": true,
  "separateMajorMinor": true,
  "minimumReleaseAge": "3 days",
  "packageRules": [
    {
      "description": "Group linters and formatters",
      "groupName": "linters and formatters",
      "matchPackageNames": [
        "eslint",
        "prettier",
        "husky",
        "/^eslint/",
        "/^prettier/",
        "/^@typescript-eslint/"
      ]
    },
    {
      "description": "Group TypeScript and types",
      "groupName": "TypeScript and types",
      "matchPackageNames": ["typescript", "/^@types/"]
    },
    {
      "description": "Group Cloudflare ecosystem",
      "groupName": "Cloudflare ecosystem",
      "matchPackageNames": ["/^@cloudflare/", "wrangler"]
    },
    {
      "description": "Fast-track patch updates and digests to 1 day",
      "matchUpdateTypes": ["patch", "digest"],
      "minimumReleaseAge": "1 day"
    },
    {
      "description": "Fast-track minor devDependencies updates to 1 day",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "1 day"
    },
    {
      "description": "Require manual review for major updates (Overrides root automerge)",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "minimumReleaseAge": "7 days",
      "labels": ["dependencies", "major-update"]
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "minimumReleaseAge": "0 days",
    "schedule": ["before 4am on monday"]
  },
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "minimumReleaseAge": "0 days"
  }
}
